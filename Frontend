/**
 * Mathematical ML Risk Prediction
 */
function updateMLPrediction() {
    const history = systemStats.analysisHistory;
    if (history.length === 0) return;
    
    // Weighted average of the last 5 prompts (recent prompts matter more)
    const recent = history.slice(-5);
    let weightSum = 0;
    let weightedScore = 0;
    
    recent.forEach((h, index) => {
        const weight = index + 1; // Gives higher weight to more recent prompts
        weightedScore += h.score * weight;
        weightSum += weight;
    });
    
    const predictedRisk = weightedScore / weightSum;
    
    let riskLabel = 'LOW';
    if (predictedRisk >= 60) riskLabel = 'HIGH';
    else if (predictedRisk >= 30) riskLabel = 'MEDIUM';
    
    const gaugeFill = document.querySelector('.gauge-fill');
    if (gaugeFill) gaugeFill.style.width = predictedRisk + '%';
    
    const predictionEl = document.getElementById('mlPrediction');
    if (predictionEl) {
        predictionEl.innerHTML = `
            <strong>AI Risk Assessment:</strong><br>
            Based on a weighted behavioral analysis of recent traffic, predicted threat probability is <span style="color: ${riskLabel === 'HIGH' ? '#ef4444' : (riskLabel === 'MEDIUM' ? '#f59e0b' : '#10b981')}">${riskLabel}</span>.
            <br>Calculated Risk Index: ${predictedRisk.toFixed(1)}%
        `;
    }
    const mlRiskLevel = document.getElementById('mlRiskLevel');
    if(mlRiskLevel) {
        mlRiskLevel.textContent = riskLabel;
        mlRiskLevel.className = `risk-badge ${riskLabel.toLowerCase()}`;
    }
}

