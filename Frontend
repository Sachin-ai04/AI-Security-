/**
 * Real Telemetry Analytics
 */
function generateAnalytics() {
    const history = systemStats.analysisHistory;
    if (history.length === 0) return;
    
    const total = history.length;
    const blocked = history.filter(h => h.isBlocked).length;
    
    // Real Accuracy: 100% minus the rate of user-reported False Positives
    const falsePositives = systemStats.falsePositives || 0;
    let accuracy = 100;
    if (total > 0) accuracy = Math.max(0, 100 - ((falsePositives / total) * 100));
    
    // Real Network Response Time (Averaged)
    let avgTime = 0;
    if (systemStats.responseTimes && systemStats.responseTimes.length > 0) {
        avgTime = systemStats.responseTimes.reduce((a, b) => a + b, 0) / systemStats.responseTimes.length;
    }
    
    // Real False Positive Rate
    let fpRate = blocked > 0 ? (falsePositives / blocked) * 100 : 0;
    
    // Real Detection Rate (Threats successfully caught vs total requests)
    const threatsCaught = history.filter(h => h.isBlocked || h.honeypotActivated).length;
    let detectionRate = total > 0 ? (threatsCaught / total * 100) : 100;
    
    document.getElementById('accuracyScore').textContent = accuracy.toFixed(1) + '%';
    document.getElementById('responseTime').textContent = avgTime.toFixed(0) + 'ms';
    document.getElementById('falsePositiveRate').textContent = fpRate.toFixed(1) + '%';
    document.getElementById('detectionRate').textContent = detectionRate.toFixed(1) + '%';
}

/**
 * Real Executive KPIs
 */
function updateKPICards() {
    const history = systemStats.analysisHistory;
    const kpiCards = document.querySelectorAll('.kpi-card');
    if (history.length === 0) return;

    // Security Score: 10 minus the average threat score of all traffic
    const avgThreat = history.reduce((sum, h) => sum + h.score, 0) / history.length;
    const securityScore = Math.max(0, 10 - (avgThreat / 10));
    if (kpiCards[0]) kpiCards[0].querySelector('.kpi-value').textContent = securityScore.toFixed(1) + '/10';
    
    // Prevention Rate: Blocked threats / Total actual threats
    const totalThreats = history.filter(h => h.score >= 50).length;
    const prevented = history.filter(h => h.isBlocked || h.honeypotActivated).length;
    const preventionRate = totalThreats > 0 ? (prevented / totalThreats * 100) : 100;
    if (kpiCards[1]) kpiCards[1].querySelector('.kpi-value').textContent = preventionRate.toFixed(1) + '%';
    
    // Risk Exposure: Count of recent critical threats
    const recentCritical = history.slice(-5).filter(h => h.level === 'critical').length;
    const riskLevel = recentCritical === 0 ? 'LOW' : (recentCritical <= 2 ? 'MEDIUM' : 'HIGH');
    if (kpiCards[2]) kpiCards[2].querySelector('.kpi-value').textContent = riskLevel;
    
    // System Uptime: Successful API calls vs Python server crashes
    const totalReqs = (systemStats.successfulRequests || 0) + (systemStats.failedRequests || 0);
    const uptime = totalReqs > 0 ? ((systemStats.successfulRequests || 0) / totalReqs * 100) : 100;
    if (kpiCards[3]) kpiCards[3].querySelector('.kpi-value').textContent = uptime.toFixed(2) + '%';
}

