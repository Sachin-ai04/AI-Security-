/**
 * Local Storage Management
 */
function saveToLocalStorage() {
    localStorage.setItem('atlasSettings', JSON.stringify(settings));
    localStorage.setItem('atlasStats', JSON.stringify(systemStats));
    localStorage.setItem('atlasChartData', JSON.stringify(chartData));
    localStorage.setItem('atlasAttackerDNA', JSON.stringify(attackerDNA));
}

function loadFromLocalStorage() {
    const savedSettings = localStorage.getItem('atlasSettings');
    const savedStats = localStorage.getItem('atlasStats');
    const savedChart = localStorage.getItem('atlasChartData');
    const savedDNA = localStorage.getItem('atlasAttackerDNA');
    
    if (savedSettings) Object.assign(settings, JSON.parse(savedSettings));
    if (savedStats) Object.assign(systemStats, JSON.parse(savedStats));
    if (savedChart) Object.assign(chartData, JSON.parse(savedChart));
    if (savedDNA) Object.assign(attackerDNA, JSON.parse(savedDNA));
    
    updateSettingsUI();
    updateDashboardDisplay();
}

function updateSettingsUI() {
    threatSensitivityInput.value = settings.threatSensitivity;
    updateSensitivityLabel();
    voiceEnabledInput.checked = settings.voiceEnabled;
    notificationsEnabledInput.checked = settings.notificationsEnabled;
}

/**
 * Theme Management
 */
function toggleTheme() {
    const isDark = document.body.classList.contains('light-theme') === false;
    if (isDark) {
        document.body.classList.add('light-theme');
        settings.theme = 'light';
        themeToggle.textContent = '☀️';
    } else {
        document.body.classList.remove('light-theme');
        settings.theme = 'dark';
        themeToggle.textContent = '🌙';
    }
    saveToLocalStorage();
    showToast(`Switched to ${settings.theme} mode`, 'success');
}

function applyTheme() {
    if (settings.theme === 'light') {
        document.body.classList.add('light-theme');
        themeToggle.textContent = '☀️';
    } else {
        themeToggle.textContent = '🌙';
    }
}

/**
 * Settings Panel Management
