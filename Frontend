function updateSensitivity() {
    settings.threatSensitivity = parseInt(threatSensitivityInput.value);
    updateSensitivityLabel();
    saveSetting();
}

function updateSensitivityLabel() {
    const value = settings.threatSensitivity;
    let label = '';
    if (value <= 3) label = 'Low';
    else if (value <= 6) label = 'Medium';
    else if (value <= 8) label = 'High';
    else label = 'Critical';
    
    document.getElementById('sensitivityValue').textContent = `${label} (${value}/10)`;
}

function saveSetting() {
    settings.voiceEnabled = voiceEnabledInput.checked;
    settings.notificationsEnabled = notificationsEnabledInput.checked;
    saveToLocalStorage();
}

/**
 * Voice Input Management
 */
function startVoiceInput() {
    if (!recognition) {
        showToast('Voice recognition not supported', 'error');
        return;
    }
    
    if (!settings.voiceEnabled) {
        showToast('Voice input is disabled in settings', 'warning');
        return;
    }
    
    voiceBtn.classList.add('recording');
    recognition.start();
}

function handleSpeechResult(event) {
    let transcript = '';
    for (let i = event.resultIndex; i < event.results.length; i++) {
        transcript += event.results[i][0].transcript;
    }
    promptInput.value = transcript;
    voiceBtn.classList.remove('recording');
}

function handleSpeechError(event) {
    voiceBtn.classList.remove('recording');
    showToast(`Voice error: ${event.error}`, 'error');
}

/**
 * Toast Notifications
 */
function showToast(message, type = 'info') {
    if (!settings.notificationsEnabled && type !== 'success') return;
    
    const toastContainer = document.getElementById('toastContainer');
    const toast = document.createElement('div');
    toast.className = `toast ${type}`;
    
    const icons = { success: '✓', error: '✕', warning: '⚠', info: 'ℹ' };
    
    toast.innerHTML = `
        <span class="toast-icon">${icons[type] || 'ℹ'}</span>
        <span class="toast-message">${message}</span>
        <button class="toast-close" onclick="this.parentElement.remove()">×</button>
    `;
    
    toastContainer.appendChild(toast);
    
    setTimeout(() => toast.remove(), 4000);
}

/**
 * Main Analysis Function - Fully Instrumented
 */
async function analyzePrompt() {
    const prompt = promptInput.value.trim();
    if (!prompt) {
        showToast('Please enter a prompt to analyze', 'warning');
        return;
    }

    analyzeBtn.textContent = 'Guard AI is Analyzing...';
    analyzeBtn.disabled = true;
    document.getElementById('actualAiResponse').textContent = "Processing connection...";
    
    // WORKFLOW STEP 1 & 2: Detection and Analysis
    updateWorkflowStep(1);
    setTimeout(() => updateWorkflowStep(2), 300);
    
    // Start the stopwatch to measure real Python server speed
    const startTime = performance.now();
    
    try {
        const response = await fetch('http://127.0.0.1:8000/api/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
                user_input: prompt,
                sensitivity: settings.threatSensitivity 
            })
        });

        if (!response.ok) throw new Error("Backend failed");
        
        const backendData = await response.json();
        
        // Stop the stopwatch
        const endTime = performance.now();
        systemStats.responseTimes.push(endTime - startTime);
        systemStats.successfulRequests++;

        // WORKFLOW STEP 3: Blocking / Routing
        updateWorkflowStep(3, backendData.status);

        const report = backendData.security_report;
        document.getElementById('actualAiResponse').textContent = backendData.ai_response;

        // Map real DNA
        if (report.threats && report.threats.length > 0) {
            report.threats.forEach(t => {
                const name = t.name.toLowerCase();
                if (name.includes('jailbreak')) attackerDNA.jailbreakAttempts++;
                else if (name.includes('role') || name.includes('persona')) attackerDNA.roleplayAttempts++;
                else if (name.includes('override') || name.includes('instruction')) attackerDNA.overrideAttempts++;
                else attackerDNA.injectionAttempts++;
            });
            
            const totalAttempts = attackerDNA.jailbreakAttempts + attackerDNA.roleplayAttempts + attackerDNA.overrideAttempts + attackerDNA.injectionAttempts;
            if (totalAttempts === 0) attackerDNA.riskLevel = 'LOW';
            else if (totalAttempts <= 2) attackerDNA.riskLevel = 'MEDIUM';
            else if (totalAttempts <= 5) attackerDNA.riskLevel = 'HIGH';
            else attackerDNA.riskLevel = 'CRITICAL';
        }

        const analysis = {
            score: report.threat_score,
            level: backendData.status === 'blocked' ? 'critical' : (backendData.status === 'honeypot' ? 'high' : 'safe'),
            threats: report.threats || [], 
            isBlocked: backendData.status === 'blocked',
            honeypotActivated: backendData.status === 'honeypot',
            decision: backendData.status,
            timestamp: new Date(),
            prompt: prompt
        };

        systemStats.analysisHistory.push(analysis);
        addBehaviorTimelineItem(analysis);
        displayResults(analysis, backendData.ai_response);
        logActivity(analysis);
        updateDashboardStats(analysis);
        updateChart(analysis.level);

        // WORKFLOW STEP 4: Reporting
        setTimeout(() => updateWorkflowStep(4), 500);

    } catch (error) {
        systemStats.failedRequests++;
        updateKPICards(); // Update uptime immediately on failure
        console.error("Error:", error);
        showToast("Connection failed.", "error");
        document.getElementById('actualAiResponse').textContent = "ERROR: Cannot connect to AI.";
    } finally {
        analyzeBtn.textContent = 'Analyze Prompt';
        analyzeBtn.disabled = false;
    }
}

// Helper function for the Incident Workflow
function updateWorkflowStep(stepNumber, decision = null) {
    const steps = document.querySelectorAll('.workflow-step');
    steps.forEach((step, index) => {
        if (index + 1 === stepNumber) {
            step.classList.add('active');
            // Dynamically change step 3 text based on AI decision
            if (stepNumber === 3 && decision) {
                const title = step.querySelector('h4');
                const desc = step.querySelector('p');
                if (decision === 'blocked') { title.textContent = 'Blocked'; desc.textContent = 'Request neutralized'; }
                else if (decision === 'honeypot') { title.textContent = 'Decoy'; desc.textContent = 'Routed to Honeypot'; }
                else { title.textContent = 'Allowed'; desc.textContent = 'Request passed safely'; }
            }
        } else {
            step.classList.remove('active');
        }
    });
}

/**
 * Threat Analysis with Sensitivity Adjustment & Honeypot Decision
 */
function performThreatAnalysis(prompt) {
    const detectedThreats = [];
    let totalScore = 0;
    let honeypotActivated = false;
    
    for (const [key, threat] of Object.entries(threatPatterns)) {
        for (const pattern of threat.patterns) {
            if (pattern.test(prompt)) {
                detectedThreats.push({
                    name: threat.name,
                    severity: threat.severity,
                    pattern: pattern.toString()
                });
                
                // Track attacker DNA
                if (threat.name === 'Jailbreak Attempt') attackerDNA.jailbreakAttempts++;
                if (threat.name === 'Role Hijack Pattern') attackerDNA.roleplayAttempts++;
                if (threat.name === 'Instruction Override') attackerDNA.overrideAttempts++;
                if (threat.name === 'XSS/Code Injection' || threat.name === 'SQL Injection') attackerDNA.injectionAttempts++;
                
                const severityScore = {
                    critical: 40,
                    high: 25,
                    medium: 15,
                    low: 5
                };
                totalScore += severityScore[threat.severity] || 0;
            }
        }
    }
    
    const uniqueThreats = Array.from(
        new Map(detectedThreats.map(t => [t.name, t])).values()
    );
    
    // Apply sensitivity multiplier
    const sensitivityMultiplier = settings.threatSensitivity / 5;
    let finalScore = Math.min(Math.round(totalScore * sensitivityMultiplier), 100);
    
    const level = determineThreatLevel(finalScore);
    
    // Honeypot Activation Logic: Activate if score is 50-69 (medium to high)
    // This tricks attackers into thinking they got somewhere
    if (finalScore >= 50 && finalScore < 70 && trickAttacker()) {
        honeypotActivated = true;
        addAlert('🍯 HONEYPOT ACTIVATED - Decoy Response Deployed', 'error', 'orange');
    }
    
    // Update attacker risk level
    const totalAttempts = attackerDNA.jailbreakAttempts + attackerDNA.roleplayAttempts + 
                          attackerDNA.overrideAttempts + attackerDNA.injectionAttempts;
    if (totalAttempts === 0) attackerDNA.riskLevel = 'LOW';
    else if (totalAttempts <= 2) attackerDNA.riskLevel = 'MEDIUM';
    else if (totalAttempts <= 5) attackerDNA.riskLevel = 'HIGH';
    else attackerDNA.riskLevel = 'CRITICAL';
    
    // Update behavio summary
    updateBehaviorSummary(uniqueThreats);
    
    const analysis = {
        score: finalScore,
        level: level,
        threats: uniqueThreats,
        isBlocked: finalScore >= 70,
        honeypotActivated: honeypotActivated,
        decision: honeypotActivated ? 'honeypot' : (finalScore >= 70 ? 'blocked' : 'safe'),
        timestamp: new Date(),
        prompt: prompt
    };
    
    systemStats.analysisHistory.push(analysis);
    addBehaviorTimelineItem(analysis);
    return analysis;
}

/**
 * Random honeypot activation to fool attackers (50% chance when triggered)
 */
function trickAttacker() {
    return Math.random() > 0.5;
}

/**
 * Determine threat level based on score
 */
function determineThreatLevel(score) {
    if (score < 20) return 'safe';
    if (score < 40) return 'low';
    if (score < 60) return 'medium';
    if (score < 80) return 'high';
    return 'critical';
}

