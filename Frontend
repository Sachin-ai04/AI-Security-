/**
 * Identify safe patterns in the prompt
 */
function identifySafePatterns(prompt) {
    const patterns = [];

    // Check for reasonable length
    if (prompt.length > 10 && prompt.length < 5000) {
        patterns.push('Reasonable prompt length');
    }

    // Check for proper sentence structure
    if (/^[A-Z]/.test(prompt)) {
        patterns.push('Proper capitalization');
    }

    // Check for normal language
    if (!/[<>{}()]/g.test(prompt) || prompt.split(/[<>{}()]/g).length < 3) {
        patterns.push('No unusual code-like characters');
    }

    // Check for clear intent
    if (/(?:what|how|tell|explain|show|find|create|make|help)/i.test(prompt)) {
        patterns.push('Clear user intent detected');
    }

    // Ensure at least 3 patterns
    while (patterns.length < 3) {
        const randomPattern = safePatternsLibrary[Math.floor(Math.random() * safePatternsLibrary.length)];
        if (!patterns.includes(randomPattern)) {
            patterns.push(randomPattern);
        }
    }

    return patterns.slice(0, 5);
}

/**
 * Activity Logging
 */
function logActivity(analysis) {
    const activityLog = document.getElementById('activityLog');
    const shortPrompt = analysis.prompt.substring(0, 50) + (analysis.prompt.length > 50 ? '...' : '');
    
    let status = '<strong>ALLOWED</strong>';
    let statusClass = 'allowed';
    if (analysis.honeypotActivated) {
        status = '<strong>HONEYPOT</strong>';
        statusClass = 'honeypot';
    } else if (analysis.isBlocked) {
        status = '<strong>BLOCKED</strong>';
        statusClass = 'blocked';
    }
    
    const threatInfo = analysis.threats.length > 0 ? ` (${analysis.threats[0].name})` : '';
    
    const activityItem = document.createElement('div');
    activityItem.className = `activity-item ${statusClass}`;
    activityItem.innerHTML = `
        <span class="time">Now</span>
        <span class="activity-text">"${shortPrompt}"${threatInfo} - ${status}</span>
    `;
    
    activityLog.insertBefore(activityItem, activityLog.firstChild);
    
    while (activityLog.children.length > 20) {
        activityLog.removeChild(activityLog.lastChild);
    }
}

/**
 * Filter Activity Log
 */
function filterActivity() {
    const searchTerm = activityFilter.value.toLowerCase();
    const items = document.querySelectorAll('.activity-item');
    
    items.forEach(item => {
        const text = item.textContent.toLowerCase();
        item.style.display = text.includes(searchTerm) ? '' : 'none';
    });
}

/**
 * Update Dashboard Stats
 */
function updateDashboardStats(analysis) {
    if (analysis.honeypotActivated) {
        systemStats.honeypotTriggers++;
        chartData.honeypot++;
        addAlert('Honeypot Triggered', 'warning', 'orange');
    } else if (analysis.isBlocked) {
        systemStats.attacksBlocked++;
        // NO MORE RANDOM NUMBERS! Math is based on the severity of the AI's threat score.
        const realFinancialLoss = (analysis.score * 1250); 
        systemStats.financialImpact += realFinancialLoss;
        addAlert('Attack Blocked', 'error', 'red');
    } else {
        addAlert('Request Allowed', 'info', 'green');
    }
    
    systemStats.totalAnalyzed++;
    updateDashboardDisplay();
}

function updateDashboardDisplay() {
    document.getElementById('attacksBlocked').textContent = systemStats.attacksBlocked.toLocaleString();
    document.getElementById('honeypotTriggers').textContent = systemStats.honeypotTriggers.toLocaleString();
    document.getElementById('financialImpact').textContent = '₹' + systemStats.financialImpact.toLocaleString();
}

/**
 * Chart Initialization and Updates
 */
function initializeChart() {
    const canvas = document.getElementById('threatChart');
    if (!canvas) return;
    
    const ctx = canvas.getContext('2d');
    
    threatChart = new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: ['Safe', 'Low Risk', 'Medium Risk', 'High Risk', 'Blocked', 'Honeypot'],
            datasets: [{
                data: [chartData.safe, chartData.low, chartData.medium, chartData.high, chartData.critical, chartData.honeypot],
                backgroundColor: [
                    '#10b981',
                    '#22c55e',
                    '#f59e0b',
                    '#ef4444',
                    '#dc2626',
                    '#fbbf24'
                ],
                borderColor: '#1e293b',
                borderWidth: 2
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    labels: { color: '#f1f5f9', font: { size: 12 } }
                }
            }
        }
    });
}

function updateChart(level) {
    if (!threatChart) return;
    
    switch(level) {
        case 'safe': chartData.safe++; break;
        case 'low': chartData.low++; break;
        case 'medium': chartData.medium++; break;
        case 'high': chartData.high++; break;
        case 'critical': chartData.critical++; break;
    }
    
    threatChart.data.datasets[0].data = [
        chartData.safe,
        chartData.low,
        chartData.medium,
        chartData.high,
        chartData.critical,
        chartData.honeypot
    ];
    threatChart.update();
}

