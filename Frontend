            <!-- Prompt Analysis Section -->
            <section class="prompt-section">
                <div class="section-header">
                    <h2>Prompt Analysis</h2>
                    <p class="section-description">Enter your prompt and let our firewall analyze it for security threats</p>
                </div>

                <div class="input-container">
                    <div class="input-wrapper">
                        <textarea 
                            id="promptInput" 
                            placeholder="Enter your prompt here..." 
                            class="prompt-input"
                        ></textarea>
                        <button id="voiceBtn" class="voice-btn" title="Voice input">🎤</button>
                    </div>
                    <button id="analyzeBtn" class="analyze-button">Analyze Prompt</button>
                </div>

