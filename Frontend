    box-shadow: 0 4px 15px rgba(59, 130, 246, 0.4);
    max-height: 55px;
    white-space: nowrap;
}

.analyze-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(59, 130, 246, 0.6);
    background: linear-gradient(135deg, #0ea5e9, var(--secondary-color));
}

.analyze-button:active {
    transform: translateY(0);
}

/* Results Container */
.results-container {
    display: flex;
    flex-direction: column;
    gap: 25px;
    animation: slideIn 0.5s ease;
}

.results-container.hidden {
    display: none;
}

@keyframes slideIn {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* Threat Score Card */
.threat-score-card {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.8), rgba(30, 41, 59, 0.8));
    border: 2px solid var(--border-color);
    border-radius: var(--border-radius);
    padding: 25px;
    transition: var(--transition);
}

.threat-score-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
}

.threat-score-header h3 {
    font-size: 1.4em;
    color: var(--text-primary);
}

.threat-level {
    padding: 8px 16px;
    border-radius: 20px;
    font-weight: 600;
    font-size: 0.9em;
    letter-spacing: 1px;
}

.threat-level.safe {
    background: rgba(16, 185, 129, 0.2);
    color: #10b981;
    border: 1px solid #10b981;
}

.threat-level.low {
    background: rgba(34, 197, 94, 0.2);
    color: #22c55e;
    border: 1px solid #22c55e;
}

.threat-level.medium {
    background: rgba(245, 158, 11, 0.2);
    color: #f59e0b;
    border: 1px solid #f59e0b;
}

.threat-level.high {
    background: rgba(239, 68, 68, 0.2);
    color: #ef4444;
    border: 1px solid #ef4444;
}

.threat-level.critical {
    background: rgba(239, 68, 68, 0.3);
    color: #ff6b6b;
    border: 1px solid #ff6b6b;
}

.threat-level.honeypot {
    background: rgba(245, 158, 11, 0.3);
    color: #fbbf24;
    border: 2px solid #fbbf24;
    font-weight: 700;
}

.threat-meter {
    width: 100%;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    overflow: hidden;
    margin-bottom: 15px;
    border: 1px solid var(--border-color);
}

.threat-bar {
    height: 100%;
    background: var(--success-color);
    transition: all 0.6s ease;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 10px;
    font-weight: 600;
    color: white;
    font-size: 0.9em;
}

.threat-score-display {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.score-label {
    color: var(--text-secondary);
    font-weight: 500;
}

.score-value {
    font-size: 1.6em;
    font-weight: 700;
    color: var(--secondary-color);
}

/* Status Card */
.status-card {
    padding: 20px;
}

.status-indicator {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 20px;
    border-radius: var(--border-radius);
    border-left: 5px solid;
    animation: pulse 2s infinite;
}

.status-indicator.safe {
    background: rgba(76, 175, 80, 0.1);
    border-left-color: #4caf50;
}

.status-indicator.blocked {
    background: rgba(244, 67, 54, 0.1);
    border-left-color: #f44336;
}

.status-icon {
    font-size: 2.5em;
    font-weight: 700;
}

.status-text h4 {
    font-size: 1.3em;
    margin-bottom: 5px;
}

.status-text p {
    color: var(--text-secondary);
    font-size: 0.95em;
}

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.8; }
}

/* Explanation Card */
.explanation-card {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.8), rgba(30, 41, 59, 0.8));
    border: 2px solid var(--border-color);
    border-radius: var(--border-radius);
    padding: 25px;
}

.explanation-card h3 {
    font-size: 1.3em;
    margin-bottom: 20px;
    color: var(--text-primary);
}

.threats-list {
    margin-bottom: 25px;
}

.threats-list h4 {
    color: #ff5252;
    margin-bottom: 15px;
    font-size: 1.1em;
}

.threats-list ul {
    list-style: none;
}

.threat-item {
    padding: 12px;
    margin-bottom: 10px;
    background: rgba(255, 82, 82, 0.1);
    border-left: 4px solid #ff5252;
    border-radius: 6px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.threat-item.critical {
    background: rgba(183, 28, 28, 0.15);
    border-left-color: #b71c1c;
}

.threat-item.high {
    background: rgba(244, 67, 54, 0.15);
    border-left-color: #f44336;
}

.threat-item.medium {
    background: rgba(255, 152, 0, 0.15);
    border-left-color: #ff9800;
}

.severity-badge {
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 0.8em;
    font-weight: 600;
    letter-spacing: 0.5px;
}

.severity-badge.critical {
    background: rgba(183, 28, 28, 0.3);
    color: #ff5252;
}

.severity-badge.high {
    background: rgba(244, 67, 54, 0.3);
    color: #ff7043;
}

.severity-badge.medium {
    background: rgba(255, 152, 0, 0.3);
    color: #ffb74d;
}

.safe-patterns {
    padding-top: 20px;
    border-top: 1px solid var(--border-color);
}

.safe-patterns h4 {
    color: #4caf50;
    margin-bottom: 15px;
    font-size: 1.1em;
}

.safe-patterns ul {
    list-style: none;
}

.safe-patterns li {
    padding: 10px;
    padding-left: 25px;
    position: relative;
    color: var(--text-secondary);
    margin-bottom: 8px;
}

.safe-patterns li:before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #4caf50;
    font-weight: 700;
    font-size: 1.1em;
}

/* Action Buttons */
.action-buttons {
    display: flex;
    gap: 10px;
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid var(--border-color);
}

.primary-btn,
.secondary-btn,
.danger-btn {
    padding: 10px 20px;
    border: none;
    border-radius: 8px;
    font-size: 0.95em;
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
}

.primary-btn {
    background: var(--secondary-color);
    color: white;
    flex: 1;
}

.primary-btn:hover {
    background: #0ea5e9;
    transform: translateY(-2px);
}

.secondary-btn {
    background: rgba(59, 130, 246, 0.2);
    color: var(--secondary-color);
    border: 1px solid var(--secondary-color);
    flex: 1;
}

.secondary-btn:hover {
    background: rgba(59, 130, 246, 0.3);
}

.danger-btn {
    background: rgba(244, 67, 54, 0.2);
    color: #f44336;
    border: 1px solid #f44336;
    width: 100%;
    margin-top: 10px;
}

.danger-btn:hover {
    background: rgba(244, 67, 54, 0.3);
}

/* Toast Notifications */
.toast-container {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 9999;
}

.toast {
    background: var(--card-bg);
    border-left: 4px solid var(--secondary-color);
    padding: 16px 20px;
    margin-bottom: 10px;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 300px;
    animation: slideInRight 0.3s ease;
}

.toast.success {
    border-left-color: #4caf50;
}

.toast.success .toast-icon {
    color: #4caf50;
}

.toast.error {
    border-left-color: #f44336;
}

.toast.error .toast-icon {
    color: #f44336;
}

.toast.warning {
    border-left-color: #ff9800;
}

.toast.warning .toast-icon {
    color: #ff9800;
}

.toast-icon {
    font-size: 1.3em;
    min-width: 20px;
}

.toast-message {
    flex: 1;
}

.toast-close {
    background: none;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    font-size: 1.2em;
    padding: 0;
}

@keyframes slideInRight {
    from {
        transform: translateX(400px);
        opacity: 0;
    }
    to {
        transform: translateX(0);
        opacity: 1;
    }
}

/* Settings Panel */
.settings-panel {
    position: fixed;
    top: 0;
    right: 0;
    width: 100%;
    max-width: 400px;
    height: 100vh;
    background: var(--card-bg);
    border-left: 2px solid var(--secondary-color);
    box-shadow: -4px 0 20px rgba(0, 0, 0, 0.5);
    z-index: 1000;
    overflow-y: auto;
    animation: slidePanel 0.3s ease;
    transform: translateX(0);
}

.settings-panel.hidden {
    display: none;
}

@keyframes slidePanel {
    from {
        transform: translateX(100%);
    }
    to {
        transform: translateX(0);
    }
}

.settings-content {
    padding: 30px;
}

.settings-content h2 {
    margin-bottom: 20px;
    padding-bottom: 15px;
    border-bottom: 2px solid var(--border-color);
}

.close-settings {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: none;
    font-size: 1.5em;
    cursor: pointer;
    color: var(--text-secondary);
    transition: var(--transition);
}

.close-settings:hover {
    color: var(--text-primary);
    transform: scale(1.2);
}

.settings-group {
    margin-bottom: 25px;
}

.settings-group label {
    display: block;
    margin-bottom: 10px;
    font-weight: 600;
    color: var(--text-primary);
}

.settings-group input[type="checkbox"] {
    margin-right: 8px;
    cursor: pointer;
}

.slider {
    width: 100%;
    height: 6px;
    background: var(--border-color);
    border-radius: 3px;
    outline: none;
    -webkit-appearance: none;
    appearance: none;
    margin-bottom: 8px;
}

.slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 20px;
    height: 20px;
    background: var(--secondary-color);
    border-radius: 50%;
    cursor: pointer;
    transition: var(--transition);
}

.slider::-webkit-slider-thumb:hover {
    background: #0ea5e9;
    transform: scale(1.1);
}

.slider::-moz-range-thumb {
    width: 20px;
    height: 20px;
    background: var(--secondary-color);
    border-radius: 50%;
    cursor: pointer;
    border: none;
    transition: var(--transition);
}

.input-field {
    width: 100%;
    padding: 10px;
    background: #0f172a;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    color: var(--text-primary);
}

#sensitivityValue {
    display: block;
    margin-top: 8px;
    color: var(--text-secondary);
    font-size: 0.9em;
}

/* Charts Section */
.charts-section {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.8), rgba(30, 41, 59, 0.8));
    border: 2px solid var(--border-color);
    border-radius: var(--border-radius);
    padding: 25px;
    margin-bottom: 30px;
}

.charts-section h3 {
    font-size: 1.3em;
    margin-bottom: 20px;
    color: var(--text-primary);
}

.chart-canvas {
    max-height: 400px;
    width: 100% !important;
}

/* Activity Section */
.activity-section {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.8), rgba(30, 41, 59, 0.8));
    border: 2px solid var(--border-color);
    border-radius: var(--border-radius);
    padding: 25px;
}

.activity-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
}

.search-input {
    padding: 10px 15px;
    background: #0f172a;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    color: var(--text-primary);
    font-size: 0.95em;
    width: 100%;
    max-width: 300px;
    margin-top: 10px;
}

.search-input:focus {
    outline: none;
    border-color: var(--secondary-color);
    box-shadow: 0 0 8px rgba(59, 130, 246, 0.2);
}

/* Modal Styles */
.modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000;
    animation: fadeIn 0.3s ease;
}

.modal.hidden {
    display: none;
}

.modal-content {
    background: var(--card-bg);
    border: 2px solid var(--secondary-color);
    border-radius: var(--border-radius);
    padding: 40px;
    max-width: 500px;
    width: 90%;
    box-shadow: 0 20px 60px rgba(107, 70, 193, 0.4);
    position: relative;
    animation: slideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.modal-close {
    position: absolute;
    top: 15px;
    right: 15px;
    background: none;
    border: none;
    font-size: 2em;
    color: var(--text-secondary);
    cursor: pointer;
    transition: var(--transition);
}

.modal-close:hover {
    color: var(--accent-color);
    transform: rotate(90deg);
}

.modal-content h2 {
    margin-bottom: 10px;
    color: var(--secondary-color);
}

.modal-content p {
    color: var(--text-secondary);
    margin-bottom: 20px;
}

#feedbackForm {
    display: flex;
    flex-direction: column;
    gap: 15px;
}

#feedbackForm textarea,
#feedbackForm select {
    padding: 12px;
    background: #0f172a;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-primary);
    font-family: inherit;
    font-size: 0.95em;
    min-height: 120px;
    resize: vertical;
}

#feedbackForm textarea:focus,
#feedbackForm select:focus {
    outline: none;
    border-color: var(--secondary-color);
    box-shadow: 0 0 10px rgba(167, 139, 250, 0.2);
}

.submit-btn {
    padding: 12px 24px;
    background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
    color: white;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: var(--smooth-animation);
}

.submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(107, 70, 193, 0.3);
}

/* Decision Buttons */
.decision-buttons {
    display: flex;
    gap: 10px;
    margin-top: 15px;
}

.report-btn {
    padding: 10px 16px;
    background: rgba(107, 70, 193, 0.2);
    color: var(--secondary-color);
    border: 1px solid var(--secondary-color);
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.9em;
    font-weight: 600;
    transition: var(--transition);
    flex: 1;
}

.report-btn:hover {
    background: rgba(107, 70, 193, 0.3);
    box-shadow: 0 4px 12px rgba(107, 70, 193, 0.2);
}

/* Attacker DNA Card */
.attacker-dna-card {
    background: linear-gradient(135deg, rgba(107, 70, 193, 0.1), rgba(236, 72, 153, 0.05));
    border: 2px solid var(--secondary-color);
    border-radius: var(--border-radius);
    padding: 25px;
    margin: 20px 0;
    animation: slideInLeft 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.attacker-dna-card.hidden {
    display: none;
}

.attacker-dna-card h3 {
    color: var(--secondary-color);
    margin-bottom: 20px;
    font-size: 1.2em;
}

.dna-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 20px;
    margin-bottom: 20px;
}

.dna-stat {
    background: rgba(15, 23, 42, 0.5);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 15px;
    text-align: center;
}

.dna-stat label {
    display: block;
    color: var(--text-secondary);
    font-size: 0.85em;
    margin-bottom: 10px;
    font-weight: 600;
}

.stat-value {
    font-size: 2.5em;
    font-weight: 700;
    color: var(--accent-color);
    margin-bottom: 10px;
}

.progress-bar {
    width: 100%;
    height: 8px;
    background: var(--border-color);
    border-radius: 4px;
    overflow: hidden;
}

.progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--primary-color), var(--accent-color));
    transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.risk-indicator {
    font-size: 1.5em;
    font-weight: 700;
    padding: 10px;
    border-radius: 8px;
    text-align: center;
}

.risk-indicator.low {
    color: #10b981;
    background: rgba(16, 185, 129, 0.1);
}

.risk-indicator.medium {
    color: #f59e0b;
    background: rgba(245, 158, 11, 0.1);
}

.risk-indicator.high {
    color: #ef4444;
    background: rgba(239, 68, 68, 0.1);
}

.behavior-summary {
    background: rgba(15, 23, 42, 0.5);
    border-left: 4px solid var(--secondary-color);
    padding: 15px;
    border-radius: 8px;
}

.behavior-summary h4 {
    color: var(--secondary-color);
    margin-bottom: 8px;
}

.behavior-summary p {
    color: var(--text-secondary);
    line-height: 1.6;
}

/* Honeypot Card */
.honeypot-card {
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.1), rgba(245, 158, 11, 0.05));
    border: 2px dashed var(--honeypot-color);
    border-radius: var(--border-radius);
    padding: 25px;
    margin: 20px 0;
    animation: slideInRight 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.honeypot-card.hidden {
    display: none;
}

.honeypot-card h3 {
    color: var(--honeypot-color);
    margin-bottom: 15px;
}

.honeypot-note {
    color: var(--honeypot-color);
    background: rgba(245, 158, 11, 0.15);
    padding: 12px;
    border-radius: 8px;
    margin-bottom: 15px;
    font-size: 0.9em;
    font-weight: 600;
}

.decoy-response {
    background: #0f172a;
    border: 1px solid var(--border-color);
    padding: 20px;
    border-radius: 10px;
    margin-bottom: 15px;
    max-height: 300px;
    overflow-y: auto;
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.6;
}

.honeypot-footer {
    text-align: center;
    padding: 12px;
    background: rgba(245, 158, 11, 0.1);
    border-radius: 8px;
}

.honeypot-label {
    color: var(--honeypot-color);
    font-weight: 600;
    font-size: 0.9em;
}

/* Alerts Centre */
.alerts-centre {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.8), rgba(30, 41, 59, 0.8));
    border: 2px solid var(--secondary-color);
    border-radius: var(--border-radius);
    padding: 25px;
    margin: 30px 0;
}

.centre-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    border-bottom: 2px solid var(--border-color);
    padding-bottom: 15px;
}

.centre-header h3 {
    color: var(--secondary-color);
    margin: 0;
}

.clear-btn {
    padding: 8px 16px;
    background: rgba(239, 68, 68, 0.2);
    color: #ef4444;
    border: 1px solid #ef4444;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.85em;
    transition: var(--transition);
}

.clear-btn:hover {
    background: rgba(239, 68, 68, 0.3);
}

.alerts-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-height: 300px;
    overflow-y: auto;
}

.alert-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 8px;
    border-left: 4px solid;
    font-size: 0.95em;
    animation: slideInLeft 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.alert-severity {
    min-width: 50px;
    font-weight: 700;
    font-size: 0.8em;
    padding: 4px 8px;
    border-radius: 4px;
    text-align: center;
}

.alert-green {
    background: rgba(16, 185, 129, 0.1);
    border-left-color: #10b981;
}

.alert-green .alert-severity {
    background: rgba(16, 185, 129, 0.3);
    color: #10b981;
}

.alert-orange {
    background: rgba(245, 158, 11, 0.1);
    border-left-color: #f59e0b;
}

.alert-orange .alert-severity {
    background: rgba(245, 158, 11, 0.3);
    color: #f59e0b;
}

.alert-red {
    background: rgba(239, 68, 68, 0.1);
    border-left-color: #ef4444;
}

.alert-red .alert-severity {
    background: rgba(239, 68, 68, 0.3);
    color: #ef4444;
}

.alert-text {
    flex: 1;
    color: var(--text-primary);
}

.alert-time {
    color: var(--text-secondary);
    font-size: 0.85em;
    white-space: nowrap;
}

/* Behavior Timeline */
.behavior-timeline {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.8), rgba(30, 41, 59, 0.8));
    border: 2px solid var(--secondary-color);
    border-radius: var(--border-radius);
    padding: 25px;
    margin: 30px 0;
}

.behavior-timeline h3 {
    color: var(--secondary-color);
    margin-bottom: 25px;
}

.timeline-container {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.timeline-info {
    text-align: center;
    padding: 20px;
    color: var(--text-secondary);
    font-style: italic;
}

.timeline-item {
    position: relative;
    padding: 20px;
    background: rgba(15, 23, 42, 0.5);
    border: 1px solid var(--border-color);
    border-left: 4px solid var(--secondary-color);
    border-radius: 10px;
    animation: slideInUp 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.timeline-item.escalating {
    border-left-color: var(--accent-color);
}

.timeline-item.critical {
    border-left-color: #ef4444;
    background: rgba(239, 68, 68, 0.05);
}

.timeline-item::before {
    content: '';
    position: absolute;
    left: -15px;
    top: 25px;
    width: 12px;
    height: 12px;
    background: var(--secondary-color);
    border: 3px solid var(--card-bg);
    border-radius: 50%;
}

.timeline-item.escalating::before {
    background: var(--accent-color);
}

.timeline-item.critical::before {
    background: #ef4444;
    width: 16px;
    height: 16px;
    left: -18px;
    top: 22px;
    animation: pulse 2s infinite;
}

.timeline-number {
    display: inline-block;
    background: var(--secondary-color);
    color: white;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 0.8em;
    font-weight: 700;
    margin-right: 10px;
}

.timeline-prompt {
    color: var(--text-secondary);
    margin: 10px 0;
    padding: 10px;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 6px;
    font-style: italic;
    font-size: 0.9em;
}

.timeline-threat {
    display: inline-block;
    padding: 4px 12px;
    background: rgba(239, 68, 68, 0.2);
    color: #ef4444;
    border-radius: 20px;
    font-size: 0.85em;
    font-weight: 600;
}

.timeline-progression {
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid var(--border-color);
    font-size: 0.9em;
    color: var(--text-secondary);
}

/* Animations */
@keyframes fadeIn {
    from {
        opacity: 0;
    }
    to {
        opacity: 1;
    }
}

@keyframes slideUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes slideInLeft {
    from {
        opacity: 0;
        transform: translateX(-20px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

@keyframes slideInRight {
    from {
        opacity: 0;
        transform: translateX(20px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}
.mission-control {
    display: flex;
    flex-direction: column;
}

.dashboard-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
}

.dashboard-card {
    background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
    border: 2px solid var(--border-color);
    border-radius: var(--border-radius);
    padding: 25px;
    display: flex;
    align-items: center;
    gap: 20px;
    transition: var(--transition);
    cursor: pointer;
    overflow: hidden;
    position: relative;
}

.dashboard-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(15, 23, 42, 0));
    opacity: 0;
    transition: var(--transition);
}

.dashboard-card:hover {
    border-color: var(--secondary-color);
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(59, 130, 246, 0.2);
}

.dashboard-card:hover::before {
    opacity: 1;
}

.card-icon {
    font-size: 3em;
    min-width: 60px;
    text-align: center;
    z-index: 1;
}

.card-content {
    flex: 1;
    z-index: 1;
}

.card-label {
    color: var(--text-secondary);
    font-size: 0.9em;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
}

.card-value {
    font-size: 2em;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 5px;
}

.card-subtitle {
    color: var(--text-secondary);
    font-size: 0.85em;
}

/* Activity Section */
.activity-section {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.8), rgba(30, 41, 59, 0.8));
    border: 2px solid var(--border-color);
    border-radius: var(--border-radius);
    padding: 25px;
}

.activity-section h3 {
    font-size: 1.3em;
    margin-bottom: 20px;
    color: var(--text-primary);
}

.activity-log {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.activity-item {
    padding: 15px;
    border-radius: 8px;
    display: flex;
    gap: 15px;
    align-items: center;
    border-left: 4px solid;
    transition: var(--transition);
}

.activity-item:hover {
    transform: translateX(5px);
}

.activity-item.blocked {
    background: rgba(239, 68, 68, 0.1);
    border-left-color: #ef4444;
}

.activity-item.allowed {
    background: rgba(16, 185, 129, 0.1);
    border-left-color: #10b981;
}

.activity-item.honeypot {
    background: rgba(245, 158, 11, 0.1);
    border-left-color: #f59e0b;
    animation: pulse 2s infinite;
}

.activity-item .time {
    color: var(--text-secondary);
    font-size: 0.85em;
    min-width: 70px;
}

.activity-text {
    flex: 1;
    color: var(--text-primary);
}

/* Footer */
.footer {
    text-align: center;
    padding: 30px 20px;
    color: var(--text-secondary);
    border-top: 1px solid var(--border-color);
    margin-top: 50px;
}

.footer p {
    font-size: 0.95em;
}

/* Responsive Design */
@media (max-width: 768px) {
    .header h1 {
        font-size: 2em;
    }

    .input-container {
        flex-direction: column;
    }

    .analyze-button {
        width: 100%;
    }

    .dashboard-grid {
        grid-template-columns: 1fr;
    }

    .status-indicator {
        flex-direction: column;
        text-align: center;
    }

    .threat-score-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
    }

    .settings-panel {
        max-width: 100%;
    }

    .action-buttons {
        flex-direction: column;
    }

    .action-buttons button {
        width: 100%;
    }
}

@media (max-width: 480px) {
    .container {
        padding: 0 15px;
    }

    section {
        padding: 20px;
    }

    .header {
        padding: 25px 15px;
    }

    .header h1 {
        font-size: 1.5em;
    }

    .subtitle {
        font-size: 0.95em;
    }

    .section-header h2 {
        font-size: 1.4em;
    }

    .card-value {
        font-size: 1.5em;
    }
}

/* Scrollbar Styling */
::-webkit-scrollbar {
    width: 10px;
}

::-webkit-scrollbar-track {
    background: var(--dark-bg);
}

::-webkit-scrollbar-thumb {
    background: var(--secondary-color);
    border-radius: 5px;
}

::-webkit-scrollbar-thumb:hover {
    background: #0ea5e9;
}

/* Print Styles */
@media print {
    body {
        background: white;
        color: black;
    }

    section {
        page-break-inside: avoid;
        border: 1px solid #ccc;
    }
}

/* Advanced Analytics Dashboard */
.analytics-dashboard {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.8), rgba(30, 41, 59, 0.8));
    border: 2px solid var(--secondary-color);
    border-radius: var(--border-radius);
    padding: 25px;
    margin: 30px 0;
}

.analytics-dashboard h3 {
    color: var(--secondary-color);
    margin-bottom: 20px;
}

.analytics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
}

.metric-card {
    background: rgba(15, 23, 42, 0.5);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 20px;
    text-align: center;
}

.metric-card label {
    display: block;
    color: var(--text-secondary);
    font-size: 0.85em;
    margin-bottom: 10px;
    font-weight: 600;
}

.metric-value {
    font-size: 2em;
    font-weight: 700;
    color: var(--secondary-color);
    margin: 10px 0;
}

.metric-detail {
    color: var(--text-secondary);
    font-size: 0.8em;
    margin-top: 8px;
}

/* Threat Intelligence Feed */
.threat-feed {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.8), rgba(30, 41, 59, 0.8));
    border: 2px solid var(--secondary-color);
    border-radius: var(--border-radius);
    padding: 25px;
    margin: 30px 0;
}

.threat-feed h3 {
    color: var(--secondary-color);
    margin-bottom: 20px;
}

.feed-container {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.feed-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 15px;
    border-radius: 8px;
    border-left: 4px solid;
    animation: slideInLeft 0.4s ease;
}

.feed-item.critical {
    background: rgba(239, 68, 68, 0.1);
    border-left-color: #ef4444;
}

.feed-item.high {
    background: rgba(245, 158, 11, 0.1);
    border-left-color: #f59e0b;
}

.feed-item.medium {
    background: rgba(107, 70, 193, 0.1);
    border-left-color: var(--secondary-color);
}

.feed-type {
    font-weight: 700;
    font-size: 0.8em;
    padding: 4px 8px;
    border-radius: 4px;
    background: rgba(0, 0, 0, 0.3);
    min-width: 60px;
    text-align: center;
    color: white;
}

.feed-text {
    flex: 1;
    color: var(--text-primary);
}

.feed-time {
    color: var(--text-secondary);
    font-size: 0.85em;
    white-space: nowrap;
}

/* Executive Dashboard */
.executive-dashboard {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.8), rgba(30, 41, 59, 0.8));
    border: 2px solid var(--secondary-color);
    border-radius: var(--border-radius);
    padding: 25px;
    margin: 30px 0;
}

.executive-dashboard h3 {
    color: var(--secondary-color);
    margin-bottom: 20px;
}

.kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 15px;
}

.kpi-card {
    padding: 20px;
    border-radius: 12px;
    border: 2px solid;
    text-align: center;
    transition: var(--smooth-animation);
}

.kpi-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
}

.kpi-card.success {
    background: rgba(16, 185, 129, 0.1);
    border-color: #10b981;
}

.kpi-card.info {
    background: rgba(107, 70, 193, 0.1);
    border-color: var(--secondary-color);
}

.kpi-card.warning {
    background: rgba(245, 158, 11, 0.1);
    border-color: #f59e0b;
}

.kpi-card h4 {
    color: var(--text-primary);
    margin-bottom: 10px;
}

.kpi-value {
    font-size: 1.8em;
    font-weight: 700;
    color: var(--secondary-color);
    margin: 10px 0;
}

.kpi-card p {
    color: var(--text-secondary);
    font-size: 0.9em;
}

/* Incident Response Workflow */
.incident-response {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.8), rgba(30, 41, 59, 0.8));
    border: 2px solid var(--secondary-color);
    border-radius: var(--border-radius);
    padding: 25px;
    margin: 30px 0;
}

.incident-response h3 {
    color: var(--secondary-color);
    margin-bottom: 20px;
}

.workflow-timeline {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    position: relative;
}

.workflow-timeline::before {
    content: '';
    position: absolute;
    top: 30px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--secondary-color);
    z-index: 0;
}

.workflow-step {
    flex: 1;
    position: relative;
    z-index: 1;
    opacity: 0.6;
    transition: var(--transition);
}

.workflow-step.active {
    opacity: 1;
}

.step-number {
    width: 60px;
    height: 60px;
    background: var(--card-bg);
    border: 3px solid var(--border-color);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.2em;
    color: var(--secondary-color);
    margin: 0 auto;
}

.workflow-step.active .step-number {
    background: var(--secondary-color);
    color: white;
    border-color: var(--secondary-color);
    box-shadow: 0 0 20px rgba(167, 139, 250, 0.5);
}

.step-content {
    text-align: center;
    margin-top: 15px;
}

.step-content h4 {
    color: var(--text-primary);
    margin-bottom: 5px;
}

.step-content p {
    color: var(--text-secondary);
    font-size: 0.9em;
}

/* ML Prediction */
.ml-prediction {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.8), rgba(30, 41, 59, 0.8));
    border: 2px solid var(--secondary-color);
    border-radius: var(--border-radius);
    padding: 25px;
    margin: 30px 0;
}

.ml-prediction h3 {
    color: var(--secondary-color);
    margin-bottom: 20px;
}

.prediction-card {
    background: rgba(15, 23, 42, 0.5);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 20px;
}

.prediction-card h4 {
    color: var(--text-primary);
    margin-bottom: 15px;
}

.risk-prediction {
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.risk-indicator {
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: var(--text-primary);
}

.risk-badge {
    padding: 6px 12px;
    border-radius: 20px;
    font-weight: 700;
    font-size: 0.9em;
}

.risk-badge.low {
    background: rgba(16, 185, 129, 0.3);
    color: #10b981;
}

.risk-badge.medium {
    background: rgba(245, 158, 11, 0.3);
    color: #f59e0b;
}

.risk-badge.high {
    background: rgba(239, 68, 68, 0.3);
    color: #ef4444;
}

.risk-gauge {
    width: 100%;
}

.gauge-bar {
    width: 100%;
    height: 12px;
    background: var(--border-color);
    border-radius: 6px;
    overflow: hidden;
}

.gauge-fill {
    height: 100%;
    background: linear-gradient(90deg, #10b981, #f59e0b, #ef4444);
    transition: width 0.8s ease;
}

#mlPrediction {
    color: var(--text-secondary);
    font-size: 0.95em;
    line-height: 1.6;
}

/* Compliance Section */
.compliance-section {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.8), rgba(30, 41, 59, 0.8));
    border: 2px solid var(--secondary-color);
    border-radius: var(--border-radius);
    padding: 25px;
    margin: 30px 0;
}

.compliance-section h3 {
    color: var(--secondary-color);
    margin-bottom: 20px;
}

.compliance-badges {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 15px;
}

.compliance-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 20px;
    background: rgba(15, 23, 42, 0.5);
    border: 2px solid var(--border-color);
    border-radius: 12px;
    text-align: center;
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 0.9em;
    transition: var(--transition);
    opacity: 0.6;
}

.compliance-badge.active {
    background: rgba(16, 185, 129, 0.1);
    border-color: #10b981;
    color: #10b981;
    opacity: 1;
}

.badge-icon {
    font-size: 2em;
}

/* Team Collaboration */
.collaboration-panel {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.8), rgba(30, 41, 59, 0.8));
    border: 2px solid var(--secondary-color);
    border-radius: var(--border-radius);
    padding: 25px;
    margin: 30px 0;
}

.collaboration-panel h3 {
    color: var(--secondary-color);
    margin-bottom: 20px;
}

.collab-features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 12px;
    margin-bottom: 25px;
}

.collab-btn {
    padding: 12px 16px;
    background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
    color: white;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: var(--smooth-animation);
}

.collab-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(107, 70, 193, 0.3);
}

.team-notes {
    background: rgba(15, 23, 42, 0.5);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 15px;
}

.team-notes h4 {
    color: var(--secondary-color);
    margin-bottom: 12px;
}

.notes-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.note-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px;
    background: rgba(0, 0, 0, 0.2);
    border-radius: 6px;
    font-size: 0.9em;
}

.note-author {
    font-weight: 600;
    color: var(--secondary-color);
    min-width: 100px;
}

.note-text {
    flex: 1;
    color: var(--text-primary);
}

.note-time {
    color: var(--text-secondary);
    font-size: 0.85em;
    white-space: nowrap;
}

/* API Documentation */
.api-docs {
    margin-top: 20px;
    max-height: 400px;
    overflow-y: auto;
}

.api-docs h3 {
    color: var(--secondary-color);
    margin: 15px 0 10px 0;
    font-size: 1.1em;
}

.api-docs pre {
    background: #0f172a;
    border: 1px solid var(--border-color);
    padding: 15px;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 15px;
}

.api-docs code {
    color: #a78bfa;
    font-family: 'Courier New', monospace;
    font-size: 0.85em;
    line-height: 1.5;
}
