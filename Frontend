<body>
    <div class="container">
        <!-- Toast Notifications -->
        <div id="toastContainer" class="toast-container"></div>

    <!-- False Positive Feedback Modal -->
    <div id="feedbackModal" class="modal hidden">
        <div class="modal-content">
            <button class="modal-close" onclick="closeFeedbackModal()">×</button>
            <h2>Report False Positive</h2>
            <p>Help us improve by reporting this analysis</p>
            <form id="feedbackForm">
                <textarea id="feedbackText" placeholder="Explain why this was a false positive..." required></textarea>
                <select id="feedbackCategory" required>
                    <option value="">Select Category</option>
                    <option value="legitimate">Legitimate Request</option>
                    <option value="false_jailbreak">False Jailbreak Detection</option>
                    <option value="false_injection">False Injection Detection</option>
                    <option value="other">Other</option>
                </select>
                <button type="submit" class="submit-btn">Submit Feedback</button>
            </form>
        </div>
    </div>

        <!-- Settings Panel -->
        <div id="settingsPanel" class="settings-panel hidden">
            <div class="settings-content">
                <h2>Settings & Configuration</h2>
                <button class="close-settings" onclick="toggleSettings()">✕</button>
                
                <div class="settings-group">
                    <label>Threat Sensitivity</label>
                    <input type="range" id="threatSensitivity" min="1" max="10" value="5" class="slider">
                    <span id="sensitivityValue">Medium (5/10)</span>
                </div>

                <div class="settings-group">
                    <label>Auto-Analysis Delay (ms)</label>
                    <input type="number" id="autoDelay" min="100" max="5000" value="500" class="input-field">
                </div>

                <div class="settings-group">
                    <label>
                        <input type="checkbox" id="voiceEnabled" checked>
                        Enable Voice Input
                    </label>
                </div>

                <div class="settings-group">
                    <label>
                        <input type="checkbox" id="notificationsEnabled" checked>
                        Enable Notifications
                    </label>
                </div>

                <button onclick="clearAllData()" class="danger-btn">Clear All History</button>
                <button onclick="downloadData()" class="primary-btn">Download Data</button>
            </div>
        </div>

        <!-- Header -->
        <header class="header">
            <div class="header-content">
                <div class="header-top">
                    <h1>🛡️ ATLAS AI Firewall</h1>
                    <div class="header-controls">
                        <button id="themeToggle" class="control-btn" title="Toggle theme">🌙</button>
                        <button id="settingsBtn" class="control-btn" onclick="toggleSettings()" title="Settings">⚙️</button>
                    </div>
                </div>
                <p class="subtitle">Advanced Threat Detection & Prompt Security</p>
            </div>
        </header>

        <!-- Main Content -->
